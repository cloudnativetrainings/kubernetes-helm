{
  "name": "Kubernetes Helm Training Labs",
  "image": "quay.io/kubermatic-labs/training-ghcs-kubernetes-helm-trainee-environment:1.0.3",
  "customizations": {
    "vscode": {
      "settings": {
        "chat.agent.enabled": false,
        "chat.commandCenter.enabled": false,
        "chat.disableAIFeatures": true,
        "telemetry.feedback.enabled": false,
        "telemetry.telemetryLevel": "off",
        "workbench.editorAssociations": {
          "*.md": "vscode.markdown.preview.editor"
        },
        "workbench.settings.applyToAllProfiles": [
          "chat.agent.enabled",
          "chat.commandCenter.enabled",
          "chat.disableAIFeatures",
          "telemetry.feedback.enabled",
          "telemetry.telemetryLevel"
        ],
        "files.exclude": {
          ".git/": true,
          ".gitignore": true,
          ".devcontainer/": true,
          ".99_todos/": true,
          "pre-checks.sh": true,
          "makefile": true,
          ".claude/": true,
          "CLAUDE.md": true
        }
      }
    }
  },
  "features": {
    "ghcr.io/devcontainers/features/docker-outside-of-docker:1": {
      "enableNonRootDocker": "true",
      "moby": "true"
    }
  },
  "remoteUser": "root",
  "runArgs": [
    "--network=host"
  ],
  "forwardPorts": [
    8080,
    80,
    443
  ],
  "postCreateCommand": "/setup_kind_cluster.sh",
  "postStartCommand": [
    "bash",
    "-c",
    "pgrep -f 'port-forward svc/ingress-nginx-controller' >/dev/null || nohup bash -c 'while true; do kubectl port-forward svc/ingress-nginx-controller -n ingress-nginx 8080:80; sleep 10; done' >/tmp/ingress-port-forward.log 2>&1 &"
  ]
}